# Copy this file to .env for local development.
# In production, set these as environment variables in Railway's dashboard.
# NEVER commit .env — it is gitignored.

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# Spoonacular API key — https://spoonacular.com/food-api
SPOONACULAR_API_KEY=your_spoonacular_key_here

# Generate with: node -p "require('crypto').randomBytes(48).toString('hex')"
JWT_SECRET=a_long_random_string_at_least_32_characters
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins (no trailing slash)
# e.g. https://finest-diners.vercel.app,https://www.finest-diners.com
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app

# Paystack payment gateway - https://paystack.com
# Test keys (use these for development)
PAYSTACK_SECRET_KEY=sk_test_a3dd114841639095559cad6e547a81b2b3672a04
PAYSTACK_PUBLIC_KEY=pk_test_df85aee32886337a113399b010de54f2826e3066
